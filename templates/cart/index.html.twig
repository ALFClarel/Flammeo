{% extends 'base.html.twig' %}

{% block title %}Mon panier - Flammeo{% endblock %}

{% block body %}
    <main style="max-width: 1000px; margin: 40px auto; padding: 0 20px;">
        <h1>Mon panier</h1>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div style="padding: 12px; margin: 12px 0; border: 1px solid #ddd;">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% if items is empty %}
            <p>Ton panier est vide.</p>

            <p>
                <a href="{{ path('app_home') }}">Voir les bougies disponibles</a>
            </p>
        {% else %}
            <div style="display: grid; gap: 20px;">
                {% for item in items %}
                    {% set product = item.product %}

                    <article style="display: flex; gap: 20px; align-items: center; border: 1px solid #ddd; padding: 16px;">
                        <div style="width: 120px; height: 120px; background: #f3f3f3; display: flex; align-items: center; justify-content: center;">
                            {% if product.imageName %}
                                <img
                                    src="{{ asset('uploads/products/' ~ product.imageName) }}"
                                    alt="{{ product.name }}"
                                    style="width: 100%; height: 100%; object-fit: cover;"
                                >
                            {% else %}
                                <span>Aucune image</span>
                            {% endif %}
                        </div>

                        <div style="flex: 1;">
                            <h2 style="margin: 0 0 8px;">{{ product.name }}</h2>
                            <p style="margin: 0;">
                                {{ product.price|number_format(2, ',', ' ') }} €
                            </p>
                        </div>

                        <form method="post" action="{{ path('app_cart_remove', { id: product.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('cart_remove_' ~ product.id) }}">

                            <button type="submit">Retirer</button>
                        </form>
                    </article>
                {% endfor %}
            </div>

            <hr style="margin: 30px 0;">

            <div style="display: flex; justify-content: space-between; align-items: center;">
                <strong>Total : {{ total|number_format(2, ',', ' ') }} €</strong>

                <div style="display: flex; gap: 12px;">
                    <form method="post" action="{{ path('app_cart_clear') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('cart_clear') }}">

                        <button type="submit">Vider le panier</button>
                    </form>

                    <form method="post" action="{{ path('app_checkout') }}" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('checkout') }}">

                        <button type="submit">
                            Payer
                        </button>
                    </form>
                </div>
            </div>
        {% endif %}
    </main>
{% endblock %}
