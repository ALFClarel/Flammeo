{% extends 'base.html.twig' %}

{% block title %}Mon panier - Flammeo{% endblock %}

{% block body %}
    <main class="page-main cart-page">
        <h1>Mon panier</h1>

        {% if app.flashes|length > 0 %}
            <div class="flash-list">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="flash">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
        {% endif %}

        {% if items is empty %}
            <div class="cart-empty">
                <p>Ton panier est vide.</p>

                <p>
                    <a href="{{ path('app_home') }}" class="btn btn-primary">Voir les bougies disponibles</a>
                </p>
            </div>
        {% else %}
            <div class="cart-items">
                {% for item in items %}
                    {% set product = item.product %}

                    <article class="cart-item">
                        <div class="cart-item__image">
                            {% if product.imageName %}
                                <img
                                    src="{{ asset('uploads/products/' ~ product.imageName) }}"
                                    alt="{{ product.name }}"
                                >
                            {% else %}
                                <span>Aucune image</span>
                            {% endif %}
                        </div>

                        <div class="cart-item__info">
                            <h2>{{ product.name }}</h2>
                            <p>
                                {{ product.price|number_format(2, ',', ' ') }} €
                            </p>
                        </div>

                        <form method="post" action="{{ path('app_cart_remove', { id: product.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('cart_remove_' ~ product.id) }}">

                            <button type="submit" class="btn btn-danger">Retirer</button>
                        </form>
                    </article>
                {% endfor %}
            </div>

            <hr class="cart-divider">

            <div class="cart-footer">
                <strong class="cart-total">Total : {{ total|number_format(2, ',', ' ') }} €</strong>

                <div class="cart-actions">
                    <form method="post" action="{{ path('app_cart_clear') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('cart_clear') }}">

                        <button type="submit" class="btn btn-outline">Vider le panier</button>
                    </form>

                    <form method="post" action="{{ path('app_checkout') }}" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('checkout') }}">

                        <button type="submit" class="btn btn-amber">
                            Payer
                        </button>
                    </form>
                </div>
            </div>
        {% endif %}
    </main>
{% endblock %}
